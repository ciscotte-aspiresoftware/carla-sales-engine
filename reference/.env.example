# ─── BlueBird .env.example ──────────────────────────────────────────────
# Copy to `.env` and fill in the keys before running `node api/index.js`.
# In demo mode (the default — flip on /admin), none of these need to be
# real keys; the stubs return canned responses. In real mode every key
# below is consulted at least once depending on which pipeline you run.

# ─── External API keys (real mode) ──────────────────────────────────────

# Scrapingdog — Google Maps search via the /sourcing pages + grid sweep.
# Pricing: 5 credits per Maps Search call. Free tier = 1000 credits.
# Sign up: https://www.scrapingdog.com/
SCRAPINGDOG_API_KEY=

# Firecrawl — per-company website scrape (1 credit per domain).
# You can rotate across up to 5 keys; the firecrawl util picks whichever
# still has credit. Leave the extras blank if you only have one key.
# Sign up: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=
FIRECRAWL_API_KEY_2=
FIRECRAWL_API_KEY_3=
FIRECRAWL_API_KEY_4=
FIRECRAWL_API_KEY_5=

# OpenAI — GPT classification + email generation. Default model is
# gpt-4o-mini (cheap, fast); override with BLUEBIRD_OPENAI_MODEL below.
# Sign up: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Apollo — decision-maker search + (optional) enrichment.
# Sign up: https://apollo.io/
APOLLO_API_KEY=

# ─── Tunables (optional — sensible defaults baked in) ───────────────────

# Server port. Default 3001 (Vite dev proxy in web/ points here).
BLUEBIRD_API_PORT=3001

# Override the default OpenAI model. gpt-4o-mini is the default; bump to
# gpt-4o for higher-fidelity classification / email body, o1-mini for
# reasoning-style tasks. Affects both classify and email gen routes.
# BLUEBIRD_OPENAI_MODEL=gpt-4o-mini

# Sweep cron tick interval in milliseconds. Default 30000 (30s).
# Lower = sweeps run faster but Scrapingdog hits you in tighter bursts.
# BLUEBIRD_SWEEP_TICK_MS=30000

# Per-ICP cells swept per session before the cron pauses and waits for
# the operator to hit "Resume sweeping" on the Coverage page. Default 2 —
# intentionally low to keep real-mode credit spend predictable. Bump to
# 30+ once you trust the pipeline and want long unattended runs.
# BLUEBIRD_SWEEP_BUDGET=2

# Set to "0" to disable the grid sweep cron entirely (e.g. when running
# only the paste-URL classify flow or testing without auto-sweeps).
# BLUEBIRD_SWEEP_TICK_MS=0

# Node environment. Defaults to "development" if unset.
# NODE_ENV=production
