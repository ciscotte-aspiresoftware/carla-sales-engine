# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ─────────────────────────────────────────────────────────────────
# Local: leave as SQLite
DATABASE_URL=sqlite:///./aspire_demo.db
# Production (Supabase): uncomment and paste your connection string
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── CORS ─────────────────────────────────────────────────────────────────────
# Local: localhost only
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production: add your Vercel URL (comma-separated, no trailing slash)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Optional integrations (leave unset = dormant) ────────────────────────────
# APOLLO_API_KEY=
# FIRECRAWL_API_KEY=
# TAVILY_API_KEY=tvly-...
# HUBSPOT_ACCESS_TOKEN=pat-na1-...

# ── App ──────────────────────────────────────────────────────────────────────
PACKS_DIR=./packs
ENVIRONMENT=development
