# ─── BlueBird .env.example ──────────────────────────────────────────────
# Copy to `.env` and fill in the keys before running `node api/index.js`.
# In demo mode (the default - flip on /admin), none of these need to be
# real keys; the stubs return canned responses. In real mode every key
# below is consulted at least once depending on which pipeline you run.

# ─── External API keys (real mode) ──────────────────────────────────────

# Scrapingdog - Google Maps search via the /sourcing pages + grid sweep.
# Pricing: 5 credits per Maps Search call. Free tier = 1000 credits.
# Rotates across up to 5 keys (sticky: stays on one until it hits a
# credit/rate limit, then advances to the next). Leave the extras blank if
# you only have one.
# Sign up: https://www.scrapingdog.com/
SCRAPINGDOG_API_KEY=
SCRAPINGDOG_API_KEY_2=
SCRAPINGDOG_API_KEY_3=
SCRAPINGDOG_API_KEY_4=
SCRAPINGDOG_API_KEY_5=

# Firecrawl - per-company website scrape (1 credit per domain).
# You can rotate across up to 5 keys; the firecrawl util picks whichever
# still has credit. Leave the extras blank if you only have one key.
# Sign up: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=
FIRECRAWL_API_KEY_2=
FIRECRAWL_API_KEY_3=
FIRECRAWL_API_KEY_4=
FIRECRAWL_API_KEY_5=

# ─── AI providers (multi-provider — set whichever you use) ─────────────
# The Admin → AI models page lets you choose a provider + model per task
# (classify / email / report / ICP automation). A provider is simply
# unavailable until its key is set. The app defaults to Anthropic.

# Anthropic (Claude) - default provider.
# Sign up: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI - optional, set if you want GPT models.
# Sign up: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini - optional, set if you want Gemini models.
# Sign up: https://aistudio.google.com/
GEMINI_API_KEY=

# Apollo - decision-maker search + (optional) enrichment.
# Sign up: https://apollo.io/
APOLLO_API_KEY=

# Apify - LinkedIn profile + recent-posts scraper. Triggered automatically
# during email generation when the lead has a linkedinUrl, AND we don't
# already have a fresh cached scrape (< 30 days old) for that lead.
# Cost: ~$0.009 per scraped lead (profile $0.004 + 5 posts × $0.001).
# Up to 4 keys can be rotated when one hits its credit cap. Leave extras
# blank if you only have one. Reusable across products - same tokens as
# valsource if you don't care about cross-product quotas.
# Sign up: https://apify.com/
APIFY_API_TOKEN=
APIFY_API_TOKEN_2=
APIFY_API_TOKEN_3=
APIFY_API_TOKEN_4=

# ─── HubSpot CRM push ───────────────────────────────────────────────────

# HubSpot Private App access token. Powers the "Push to HubSpot" action that
# upserts a company (dedupe by domain) with its name/address/phone + the AI
# verdict (icp_summary), rating, reviews, vertical, and signals (signalssummary),
# attaches a Note with the full report, and upserts every contact that has an
# email (associated to the company). Idempotent - re-pushing updates in place.
#
# Create at: HubSpot → Settings → Integrations → Private Apps → Create.
# Required scopes:
#   crm.objects.companies.read   crm.objects.companies.write
#   crm.objects.contacts.read    crm.objects.contacts.write
# When unset, /api/hubspot/health reports connected:false and pushes 400.
# In demo mode (/admin) pushes are a no-op stub regardless of this token.
HUBSPOT_PRIVATE_APP_TOKEN=

# Optional inbound API-key gate on the push endpoints (/api/hubspot/push*),
# same pattern as DISCOVER_API_KEY below. Unset = open (local-dev default).
HUBSPOT_PUSH_API_KEY=

# ─── Optional auth gate ─────────────────────────────────────────────────

# Optional API-key gate on /api/discover (the CRM lead-discovery pipeline).
# When set, every request must present `x-api-key: <key>` OR
# `Authorization: Bearer <key>`. When UNSET, the endpoint stays open
# (default local-dev behaviour). Set this on Render to hand the CRM team
# a credential without sharing code; rotate by changing the env var.
DISCOVER_API_KEY=

# ─── Tunables (optional - sensible defaults baked in) ───────────────────

# Server port. The code prefers PORT (Render injects this) over
# BLUEBIRD_API_PORT (local override). Default 3001 - the Vite dev proxy
# in web/ points here. On Render, leave both blank and let PORT win.
BLUEBIRD_API_PORT=3001
# PORT=10000     # Render-style; only set if you're emulating Render locally

# Override the default OpenAI model. gpt-4o-mini is the default; bump to
# gpt-4o for higher-fidelity classification / email body, o1-mini for
# reasoning-style tasks. Affects both classify and email gen routes.
# BLUEBIRD_OPENAI_MODEL=gpt-4o-mini

# Sweep cron tick interval in milliseconds. Default 5000 (5s). Lower =
# sweeps run faster but Scrapingdog hits you in tighter bursts. Bump to
# 600000 (10 min) for overnight production-style behaviour.
# Special case: set to 0 to disable the grid sweep cron entirely
# (e.g. when running only the paste-URL classify flow, or testing without
# auto-sweeps). The route handlers stay live, only the auto-loop is
# skipped.
# BLUEBIRD_SWEEP_TICK_MS=5000

# Per-ICP cells swept per session before the cron pauses and waits for
# the operator to hit "Resume sweeping" on the Coverage page. Default 2 -
# intentionally low to keep real-mode credit spend predictable. Bump to
# 30+ once you trust the pipeline and want long unattended runs.
# BLUEBIRD_SWEEP_BUDGET=2

# Restore the pre-classify Maps "type" filter on sweep candidates. By
# default this is OFF - so any vertical (laundromats, plant nurseries,
# anything not in chains.js's allow-list) gets through to GPT classify.
# Set to "true" to re-enable the credit-saving pre-filter for verticals
# that ARE in the allow-list (car_rental, etc).
# BLUEBIRD_ENABLE_TYPE_FILTER=true

# Node environment. Defaults to "development" if unset.
# NODE_ENV=production

# Demo/Real mode BOOT default. The in-app toggle persists to data/mode.json,
# but on hosts with an ephemeral filesystem (Render free tier) that file is
# wiped on every cold start, so the app silently reverts to "demo" - which
# no-ops real HubSpot pushes / Apollo enrichment / sweeps. Set this to "real"
# to pin the boot default (the toggle still works within a running instance).
# Leave unset for the original file-only behaviour (defaults to demo).
# BLUEBIRD_MODE=real

# ─── Supabase (OPTIONAL - DISABLED by default) ──────────────────────────
# Bluebird persists to JSON files under api/data/ today. Supabase is fully
# scaffolded but OFF until you flip the switch below. To migrate later:
#   1. Create a Supabase project.
#   2. Run api/db/migrations/0001_initial_schema.sql in the SQL editor,
#      then every subsequent file (0002 through the highest numbered one
#      in the folder) in strict order. Migrations are NOT idempotent and
#      depend on prior state.
#   3. Fill the three vars below (service-role key - SERVER ONLY, never ship
#      it to the browser; it bypasses row-level security).
#   4. Set USE_SUPABASE=true, then from api/ run:
#        npm install          # pulls @supabase/supabase-js
#        npm run db:status     # verify the connection
#        npm run db:import     # upload existing api/data/*.json into Supabase
# Until USE_SUPABASE=true, none of this is consulted and the app runs on JSON.
USE_SUPABASE=false
SUPABASE_URL=
SUPABASE_SERVICE_KEY=