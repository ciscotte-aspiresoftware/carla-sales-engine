# в”Ђв”Ђв”Ђ Atlas frontend .env.example в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Copy to `.env.production` before `npm run build`. Vite bakes these into
# the bundle at BUILD TIME (not runtime), so rebuild + redeploy if any
# value changes.
#
# For local dev (`npm run dev`), the Vite proxy in vite.config.ts forwards
# /api and /socket.io to localhost:3001 - so VITE_API_URL is optional in
# dev and only matters for the production build.

# Atlas backend URL. Point at your own Render service (or wherever you
# deploy the backend). Leave blank for local dev (uses the proxy).
VITE_API_URL=

# Optional - only set this if your Atlas backend has DISCOVER_API_KEY
# enabled to gate the /api/discover route. The value here will be baked
# into the bundle, so do NOT use a sensitive key if the frontend is
# served from a public URL - prefer a backend-only deploy of /discover.
VITE_DISCOVER_API_KEY=